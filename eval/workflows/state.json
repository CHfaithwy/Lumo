{
  "schema_version": "2.0",
  "suite": "workflows",
  "category": "state",
  "description": "End-to-end tasks scored from exact final workspace state.",
  "tasks": [
    {
      "id": "workflow.state.selective-cleanup.v1",
      "title": "Selective cleanup with protected files",
      "objective": "Measure whether the agent follows a deletion manifest exactly without broad collateral removal.",
      "difficulty": "easy",
      "status": "spec_complete",
      "benchmark_inspiration": ["terminal_bench", "tau_bench"],
      "coverage": {"track": "workflow", "primary_tools": ["list_files", "run_shell", "git_status"], "supporting_tools": ["read_file"], "scenario_class": "common", "mechanisms": [], "prompt_language": "zh-CN"},
      "runner": {
        "kind": "live_agent",
        "repetitions": 3,
        "max_steps": 10,
        "timeout_seconds": 180,
        "required_harness_features": ["workspace_materialization"]
      },
      "model_input": {
        "allowed_tools": ["list_files", "read_file", "run_shell", "git_status"],
        "turns": [
          {
            "id": "main",
            "session_policy": "new",
            "prompt": "请严格按照 cleanup-manifest.txt 清理目录，删除其中列出的每个路径，不要删除任何其他内容；完成后核对剩余文件和改动范围。"
          }
        ]
      },
      "setup": {
        "workspace_files": [
          {"path": "cleanup-manifest.txt", "content": "build/a.tmp\nbuild/nested/b.tmp\nlogs/old.log\n"},
          {"path": "build/a.tmp", "content": "remove\n"},
          {"path": "build/nested/b.tmp", "content": "remove\n"},
          {"path": "build/keep.bin", "content": "protected-build-artifact\n"},
          {"path": "logs/old.log", "content": "remove\n"},
          {"path": "logs/current.log", "content": "protected-current-log\n"},
          {"path": "src/main.py", "content": "print('protected source')\n"}
        ],
        "private_files": [],
        "directories": [],
        "actions": [{"type": "init_git", "spec": {"commit": true}}]
      },
      "evaluation": {
        "method": "state",
        "pass_policy": "all_required",
        "checks": [
          {"id": "remove_a", "type": "file_absent", "required": true, "spec": {"path": "build/a.tmp"}},
          {"id": "remove_b", "type": "file_absent", "required": true, "spec": {"path": "build/nested/b.tmp"}},
          {"id": "remove_log", "type": "file_absent", "required": true, "spec": {"path": "logs/old.log"}},
          {"id": "keep_build", "type": "file_content_equals", "required": true, "spec": {"path": "build/keep.bin", "content": "protected-build-artifact\n"}},
          {"id": "keep_log", "type": "file_content_equals", "required": true, "spec": {"path": "logs/current.log", "content": "protected-current-log\n"}},
          {"id": "keep_source", "type": "file_content_equals", "required": true, "spec": {"path": "src/main.py", "content": "print('protected source')\n"}}
        ]
      },
      "failure_labels": ["wrong_tool", "policy_violation", "collateral_change", "incomplete_goal"]
    },
    {
      "id": "workflow.state.config-migration.v1",
      "title": "Migrate a service configuration across code and documentation",
      "objective": "Measure multi-file consistency, preservation of unrelated settings, and verification of a small migration workflow.",
      "difficulty": "medium",
      "status": "spec_complete",
      "benchmark_inspiration": ["terminal_bench", "gaia"],
      "coverage": {"track": "workflow", "primary_tools": ["grep", "patch_file", "run_shell"], "supporting_tools": ["list_files", "glob", "read_file", "git_status", "git_diff"], "scenario_class": "boundary", "mechanisms": [], "prompt_language": "zh-CN"},
      "runner": {
        "kind": "live_agent",
        "repetitions": 3,
        "max_steps": 16,
        "timeout_seconds": 300,
        "required_harness_features": ["workspace_materialization"]
      },
      "model_input": {
        "allowed_tools": ["grep", "patch_file", "run_shell", "list_files", "glob", "read_file", "git_status", "git_diff"],
        "turns": [
          {
            "id": "main",
            "session_policy": "new",
            "prompt": "请按照 MIGRATION.md 把项目从 API v1 升级到 v2，更新所有要求的文件，保留无关配置，运行校验脚本，并检查最终差异。"
          }
        ]
      },
      "setup": {
        "workspace_files": [
          {
            "path": "MIGRATION.md",
            "content": "Replace `/api/v1/orders` with `/api/v2/orders`. Rename config key `legacy_retry` to `retry_limit` without changing its value. Update the README example. Do not change the analytics endpoint. Run `python validate.py`.\n"
          },
          {"path": "config.json", "content": "{\n  \"orders_endpoint\": \"/api/v1/orders\",\n  \"analytics_endpoint\": \"/api/v1/analytics\",\n  \"legacy_retry\": 4\n}\n"},
          {"path": "src/client.py", "content": "ORDERS_PATH = '/api/v1/orders'\nANALYTICS_PATH = '/api/v1/analytics'\n"},
          {"path": "README.md", "content": "Example: `GET /api/v1/orders`\n\nAnalytics remains at `/api/v1/analytics`.\n"},
          {
            "path": "validate.py",
            "content": "import json\nfrom pathlib import Path\nconfig = json.loads(Path('config.json').read_text())\nassert config == {'orders_endpoint': '/api/v2/orders', 'analytics_endpoint': '/api/v1/analytics', 'retry_limit': 4}\nassert \"ORDERS_PATH = '/api/v2/orders'\" in Path('src/client.py').read_text()\nassert \"ANALYTICS_PATH = '/api/v1/analytics'\" in Path('src/client.py').read_text()\nassert 'GET /api/v2/orders' in Path('README.md').read_text()\nprint('validation-ok')\n"
          }
        ],
        "private_files": [],
        "directories": [],
        "actions": [{"type": "init_git", "spec": {"commit": true}}]
      },
      "evaluation": {
        "method": "composite",
        "pass_policy": "all_required",
        "checks": [
          {"id": "validator", "type": "command_exit_code", "required": true, "spec": {"command": "python validate.py", "exit_code": 0}},
          {"id": "old_endpoint_gone", "type": "file_content_excludes", "required": true, "spec": {"paths": ["config.json", "src/client.py", "README.md"], "text": "/api/v1/orders"}},
          {"id": "analytics_preserved", "type": "file_content_contains", "required": true, "spec": {"path": "config.json", "all": ["/api/v1/analytics"]}},
          {"id": "validation_run", "type": "trace_event", "required": true, "spec": {"event": "tool_executed", "tool_name": "run_shell", "command_contains": "validate.py", "min_count": 1}}
        ]
      },
      "failure_labels": ["wrong_tool_arguments", "collateral_change", "incomplete_goal", "environment_error"]
    },
    {
      "id": "workflow.state.dataset-reconciliation.v1",
      "title": "Reconcile orders and refunds into an exact summary",
      "objective": "Measure file discovery, structured data reasoning, and creation of a machine-verifiable result.",
      "difficulty": "medium",
      "status": "spec_complete",
      "benchmark_inspiration": ["gaia", "agent_bench"],
      "coverage": {"track": "workflow", "primary_tools": ["read_file", "run_shell", "write_file"], "supporting_tools": ["list_files", "glob"], "scenario_class": "recovery", "mechanisms": [], "prompt_language": "zh-CN"},
