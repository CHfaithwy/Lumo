        "required_harness_features": ["workspace_materialization"]
      },
      "model_input": {
        "allowed_tools": ["list_files", "glob", "read_file", "run_shell", "write_file"],
        "turns": [
          {
            "id": "main",
            "session_policy": "new",
            "prompt": "请核对 data/orders.csv 和 data/refunds.json，忽略已取消订单，并生成 summary.json，包含 gross_paid、refunded、net_revenue、paid_order_count，以及升序排列的 fully_refunded_order_ids；金额均为整数元。"
          }
        ]
      },
      "setup": {
        "workspace_files": [
          {"path": "data/orders.csv", "content": "order_id,status,amount\nO-3,paid,90\nO-1,paid,120\nO-2,cancelled,75\nO-4,paid,60\n"},
          {"path": "data/refunds.json", "content": "[\n  {\"order_id\": \"O-1\", \"amount\": 20},\n  {\"order_id\": \"O-3\", \"amount\": 90},\n  {\"order_id\": \"O-2\", \"amount\": 75}\n]\n"}
        ],
        "private_files": [],
        "directories": [],
        "actions": []
      },
      "evaluation": {
        "method": "state",
        "pass_policy": "all_required",
        "checks": [
          {"id": "gross", "type": "json_value_equals", "required": true, "spec": {"path": "summary.json", "json_path": "$.gross_paid", "value": 270}},
          {"id": "refunded", "type": "json_value_equals", "required": true, "spec": {"path": "summary.json", "json_path": "$.refunded", "value": 110}},
          {"id": "net", "type": "json_value_equals", "required": true, "spec": {"path": "summary.json", "json_path": "$.net_revenue", "value": 160}},
          {"id": "count", "type": "json_value_equals", "required": true, "spec": {"path": "summary.json", "json_path": "$.paid_order_count", "value": 3}},
          {"id": "full_refunds", "type": "json_value_equals", "required": true, "spec": {"path": "summary.json", "json_path": "$.fully_refunded_order_ids", "value": ["O-3"]}}
        ]
      },
      "failure_labels": ["wrong_tool", "wrong_tool_arguments", "incomplete_goal", "hallucinated_evidence"]
    },
