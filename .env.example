# Copy this file to .env and fill only the providers you use.

# Recommended default. DeepSeek uses its Anthropic-compatible endpoint.
LUMO_DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
LUMO_DEEPSEEK_API_KEY=
LUMO_DEEPSEEK_MODEL=deepseek-v4-pro

# Optional right.codes shared key. Used by --provider openai and --provider anthropic when provider-specific keys are empty.
LUMO_RIGHT_CODES_API_KEY=

# Default OpenAI-compatible endpoint. Change this if you use another /responses-compatible service.
LUMO_OPENAI_API_BASE=https://www.codex2api.com/v1
LUMO_OPENAI_API_KEY=
LUMO_OPENAI_MODEL=gpt-5.4
LUMO_OPENAI_MODEL_EFFORT=xhigh
# Leave empty to use the model/provider default sampling temperature.
LUMO_OPENAI_TEMPERATURE=

# Default Anthropic-compatible endpoint. Can reuse LUMO_RIGHT_CODES_API_KEY when your gateway shares one key.
LUMO_ANTHROPIC_API_BASE=https://www.codex2api.com/v1
LUMO_ANTHROPIC_API_KEY=
LUMO_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional comma-separated extra env names to redact from traces and reports.
LUMO_SECRET_ENV_NAMES=
