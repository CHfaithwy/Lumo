# Ignore everything by default.
*

# Keep repository control files.
!.gitignore

# Keep project metadata and docs.
!README.md
!pyproject.toml
!.env.example
!lumo.md

# Keep source code.
!lumo/
!lumo/**

# Keep project assets.
!assets/
!assets/**

# Keep agent evaluation datasets and their validator.
!eval/
!eval/**

# Ignore local evaluation drafts and generated results.
eval/description.md
eval/description1.md
eval/results/

# Ignore generated Python artifacts even inside allowed directories.
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
build/
dist/

# Ignore local runtime state and temporary workspaces.
.lumo/
.pico/
.tmp_prompt_sessions/
.tmp_session_test/
.tmp*/
*.tmp

# Ignore non-core project materials.
benchmarks/
docs/
examples/
scripts/
tests/

# Ignore local secrets and environment files.
.env
.env.*
!.env.example

# Ignore local reference/source dumps.
lumo.egg-info/
readme_intro_locked/
